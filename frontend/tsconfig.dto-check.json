{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/types/index.ts",
    "src/types/dtoAssertions.ts",
    "src/services/generatedClient.ts",
    "src/services/api.ts"
  ]
}
