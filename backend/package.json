{
  "name": "bribecafe-backend",
  "version": "1.0.0",
  "description": "BribeCafe Backend - Agent-to-Agent Private Deal Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --skipLibCheck",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "test": "jest",
    "test:contracts": "hardhat test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network zamaDev",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "contracts:check": "npm run contracts:build && tsc -p tsconfig.contracts.json --noEmit",
    "contracts:build": "npx tsc -p ../sdk/contracts/tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@prisma/client": "^5.10.0",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.1",
    "pg": "^8.11.3",
    "siwe": "^2.1.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "chai": "^4.4.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
