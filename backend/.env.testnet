# Zama Testnet Configuration
ZAMA_RPC_URL=https://testnet.zama.ai
ZAMA_CHAIN_ID=...
ZAMA_NETWORK_NAME=zama-testnet

# Contract Addresses (filled after deployment)
CONTRACT_ESCROW_ADDRESS=
CONTRACT_TABLEFACTORY_ADDRESS=

# Treasury Address (BribeCafe fee collection)
TREASURY_ADDRESS=0x...

# Database (use free tier - see below)
DATABASE_URL=postgresql://...

# Backend Config
PORT=3000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
